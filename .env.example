# ShellForgeAI environment overrides.
# Copy to .env and adjust for your shell, or `source` it directly.

# Model provider (openai-codex | ollama | vllm | openai-compatible | openrouter)
SHELLFORGEAI_MODEL_PROVIDER=openai-codex
SHELLFORGEAI_MODEL_NAME=gpt-5.5
SHELLFORGEAI_MODEL_FALLBACK=gpt-5.4

# Codex CLI (only used by openai-codex)
SHELLFORGEAI_CODEX_BINARY=codex
SHELLFORGEAI_CODEX_TIMEOUT_SECONDS=180
SHELLFORGEAI_CODEX_SKIP_GIT_REPO_CHECK=true

# API key (used by vllm / openai-compatible / openrouter)
# SHELLFORGEAI_API_KEY=sk-...

# Optional build metadata (surfaced by --version, version, doctor)
# SHELLFORGEAI_BUILD_PR=
# SHELLFORGEAI_BUILD_COMMIT=
# SHELLFORGEAI_BUILD_BRANCH=
# SHELLFORGEAI_BUILD_DATE=
