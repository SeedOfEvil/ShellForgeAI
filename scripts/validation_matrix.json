{
  "schema_version": 1,
  "title": "ShellForgeAI validation lane impact map",
  "description": "Maps changed-file patterns to a validation lane and a recommended regression test group. This is read-only planning data consumed by scripts/validate_pr.py (PR157). It does not run anything by itself. Editing this file is itself a Lane C (full) change because it affects broad validation confidence.",
  "lane_order": ["fast", "targeted_runtime", "full"],
  "lane_letter": {"fast": "A", "targeted_runtime": "B", "full": "C"},
  "runtime_class": {"fast": "short", "targeted_runtime": "medium", "full": "long"},
  "lanes": {
    "fast": {
      "label": "Lane A: fast default",
      "full_pytest_default": false,
      "runtime_class": "short",
      "use_for": [
        "docs-only changes",
        "README/OPS/roadmap edits",
        "CLI help text only",
        "wording-only changes",
        "tests-only additions for docs/contract"
      ]
    },
    "targeted_runtime": {
      "label": "Lane B: targeted runtime",
      "full_pytest_default": false,
      "runtime_class": "medium",
      "use_for": [
        "ask routing",
        "intent parsing",
        "command dispatch",
        "interactive UX",
        "JSON output shape",
        "artifact read/validate/export behavior",
        "doctor output",
        "status/triage/propose/apply-preview/verify/handoff wording or routing",
        "recipe registry or preflight read-only logic"
      ]
    },
    "full": {
      "label": "Lane C: full validation",
      "full_pytest_default": true,
      "runtime_class": "long",
      "use_for": [
        "cleanup execution",
        "remediation execution",
        "rollback execution",
        "Docker/Compose behavior",
        "container restart behavior",
        "recipe execution",
        "apply/mission execution",
        "safety gates/refusal core rewrites",
        "broad command router rewrites",
        "pyproject/dependency/Dockerfile changes",
        "packaging/import changes",
        "test harness or validation infrastructure changes",
        "failures or suspicious targeted results",
        "high-risk unknown changes"
      ]
    }
  },
  "rules": [
