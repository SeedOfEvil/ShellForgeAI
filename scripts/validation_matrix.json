  "source_fallback": {
    "pattern": "src/**/*.py",
    "lane": "targeted_runtime",
    "reason": "unmapped source module; defaulting to targeted runtime lane (relies on PR-specific tests)",
    "warn_if_no_tests": "no PR-specific or mapped tests matched this module; add a matrix entry, pass --pr <n>, or escalate with --profile full before skipping full pytest"
  },
  "unmatched": {
    "lane": "full",
    "reason": "unrecognized changed path; full validation recommended as a safe default"
  },
  "safety_escalation": {
    "lane": "full",
    "reason": "safety/execution-boundary keyword present in changed content",
    "applies_to": "non-documentation changed content only (explicitly provided diff/content, or --scan-content). Documentation that merely describes these keywords does not escalate.",
