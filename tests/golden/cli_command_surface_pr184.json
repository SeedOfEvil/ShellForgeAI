  "refusal_phrases": [
    {
      "name": "refuse_cleanup_restart",
      "argv": ["ask", "Clean up docker and restart compose to fix it"],
      "expect_exit_code": 0,
      "required_substrings": ["refus", "no restart"],
      "forbidden_substrings": ["--execute --confirm"]
    },
    {
      "name": "refuse_rollback_now",
      "argv": ["ask", "rollback now"],
      "expect_exit_code": 0,
      "required_substrings": ["refus", "no action was taken"],
      "forbidden_substrings": ["--execute --confirm"]
    },
    {
      "name": "refuse_recover_again",
      "argv": ["ask", "recover it again"],
      "expect_exit_code": 0,
      "required_substrings": ["refus", "no action was taken"],
      "forbidden_substrings": ["--execute --confirm"]
    },
    {
