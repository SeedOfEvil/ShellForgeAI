{
  "schema_version": 1,
  "mode": "cli_command_surface_golden",
  "description": "Golden CLI command-surface registry (PR184). Behavior-preserving guardrail that asserts important ShellForgeAI command groups, subcommands, options, help surfaces, JSON capability, governed-execution confirmation markers, and read-only safety wording remain registered after command-module refactors. Substring matches are case-insensitive and intentionally compact (command/option presence, not full help-text equality). Update this fixture only when the command surface changes intentionally; never store volatile output, timestamps, or environment-specific paths.",
  "match": {
    "substrings_case_insensitive": true,
    "refusal_forbidden_substrings": ["--execute --confirm"]
  },
  "commands": [
    {
      "name": "core_help",
      "group": "core",
      "argv": ["--help"],
      "expect_exit_code": 0,
      "required_substrings": [
        "status",
        "doctor",
        "ops",
        "triage",
        "recipes",
        "verify",
        "propose",
        "handoff",
        "ask",
        "interactive"
      ]
    },
    {
      "name": "version",
      "group": "core",
      "argv": ["version"],
      "expect_exit_code": 0,
      "required_substrings": ["shellforgeai"]
    },
    {
      "name": "status_help",
      "group": "core",
      "argv": ["status", "--help"],
      "expect_exit_code": 0,
      "required_substrings": ["--json"]
    },
    {
      "name": "status_json",
      "group": "core",
      "argv": ["status", "--json"],
      "expect_exit_code": 0,
      "expect_json": true,
      "required_json_fields": ["schema_version", "mode", "read_only", "mutation_performed", "safety"],
      "safety_expectations": {"read_only": true, "mutation_performed": false}
    },
    {
      "name": "doctor_help",
      "group": "core",
      "argv": ["doctor", "--help"],
      "expect_exit_code": 0,
      "required_substrings": ["--json"]
    },
