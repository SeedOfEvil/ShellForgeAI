      "name": "doctor_json",
      "group": "core",
      "argv": ["doctor", "--json"],
      "expect_exit_code": 0,
      "expect_json": true,
      "required_json_fields": ["shellforgeai", "runtime_hygiene", "metadata_hygiene", "safety"],
      "safety_expectations": {"mutation_performed": false}
    },
    {
      "name": "model_doctor_help",
      "group": "core",
      "argv": ["model", "doctor", "--help"],
      "expect_exit_code": 0,
      "required_substrings": ["doctor"],
      "notes": "model doctor is provider-readiness only and intentionally has NO --json flag in the current surface; it is help-only here because the handler builds a provider (a model call) when invoked without --help."
    },
    {
      "name": "v1_check_help",
      "group": "v1_readiness",
      "argv": ["v1", "check", "--help"],
      "expect_exit_code": 0,
      "required_substrings": ["--profile", "--json"]
    },
    {
      "name": "v1_check_quick_json",
      "group": "v1_readiness",
      "argv": ["v1", "check", "--profile", "quick", "--json"],
      "expect_json": true,
      "required_json_fields": ["schema_version", "mode", "profile", "safety"],
      "safety_expectations": {"read_only": true, "mutation_performed": false},
      "notes": "Exit code is environment-dependent (readiness can pass or fail), so it is intentionally not pinned; only JSON validity, mode, and read-only safety are asserted."
    },
    {
      "name": "v1_check_standard_json",
      "group": "v1_readiness",
      "argv": ["v1", "check", "--profile", "standard", "--json"],
      "expect_json": true,
      "required_json_fields": ["schema_version", "mode", "profile", "safety"],
      "safety_expectations": {"read_only": true, "mutation_performed": false},
      "notes": "Exit code intentionally not pinned (environment-dependent readiness status)."
    },
